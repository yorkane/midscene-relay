# === Web Relay (midscene/web - Chrome CDP bridge) ===
# Chrome CDP URL on this machine
CDP_URL=http://127.0.0.1:9222
# SDK relay URL (Socket.IO)
RELAY_URL=ws://0.0.0.0:3768
# CDP reverse proxy URL (for Playwright connectOverCDP)
CDP_PROXY_URL=http://0.0.0.0:9223
# Feature toggles
# ENABLE_WEB_RELAY=true
# ENABLE_CDP_PROXY=true

# === Computer Relay (midscene/computer - desktop control) ===
COMPUTER_RELAY_URL=ws://0.0.0.0:3767
# ENABLE_COMPUTER_RELAY=true

# === B machine demo config ===
# NOTE: To run demos on B machine, change the host below to A machine's IP (e.g. ws://192.168.1.13:3768)
# DEMO_RELAY_URL=ws://localhost:3768
# DEMO_COMPUTER_RELAY_URL=ws://localhost:3767
GENERATE_REPORT=false

# === AI Model Config (required for B machine) ===
# MIDSCENE_MODEL_NAME=qwen3.5-plus
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://your-api-base/v1/
